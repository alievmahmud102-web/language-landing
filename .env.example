# Telegram lead notifications (Contact form → /api/telegram)
# Get token from @BotFather; chat_id is your user id or group id.
TELEGRAM_BOT_TOKEN=PASTE_YOUR_TOKEN_HERE
TELEGRAM_CHAT_ID=PASTE_YOUR_CHAT_ID_HERE

# --- Production (Vercel, Netlify, Railway, etc.) ---
# Copy this file to .env.local for `npm run dev` only on your machine.
# On the public URL, .env.local is NOT deployed: add the same two variables
# in the host UI (e.g. Vercel → Project → Settings → Environment Variables),
# scope "Production", then trigger a new deploy.
